GOOGLE_MAPS_API_KEY_ANDROID=

# Google OAuth (expo-auth-session) - Client IDs por plataforma
GOOGLE_OAUTH_CLIENT_ID_IOS=
GOOGLE_OAUTH_CLIENT_ID_ANDROID=
GOOGLE_OAUTH_CLIENT_ID_WEB=

# Facebook OAuth
FACEBOOK_APP_ID=
